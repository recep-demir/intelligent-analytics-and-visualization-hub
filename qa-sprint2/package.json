{
  "name": "eliotax-qa-sprint2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:auth": "jest tests/auth.test.js",
    "test:ai": "jest tests/ai-query.test.js --forceExit",
    "test:rbac": "jest tests/rbac.test.js",
    "test:watch": "jest --watch",
    "seed": "node fixtures/seed.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.{js,ts}"],
    "testTimeout": 10000,
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
    }
  },
  "dependencies": {
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}
